<div class="mb-4 flex flex-wrap gap-2">
  <% stats.each do |state, count| %>
    <div class="cf-stat flex items-center gap-2 rounded-md border border-zinc-200 bg-white px-3 py-1.5 text-sm">
      <%= cf_dot(state) %>
      <span class="text-zinc-500"><%= state %></span>
      <span class="font-mono font-medium tabular-nums"><%= count %></span>
    </div>
  <% end %>
</div>
