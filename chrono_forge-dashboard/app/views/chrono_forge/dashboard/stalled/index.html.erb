<div class="mb-5 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-lg font-semibold tracking-tight">Stalled workflows</h1>
    <p class="mt-1 text-sm text-zinc-500">Stopped after a step ran out of retries. Fix the cause, then retry to pick up where it left off.</p>
  </div>
  <% if @rows.any? %>
    <%= button_to "Retry all stalled & failed", bulk_retry_workflows_path, method: :post,
          form: {data: {confirm: "Re-enqueue every stalled and failed workflow?"}}, class: "cf-btn cf-btn-primary shrink-0" %>
  <% end %>
</div>

<div class="cf-card overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-zinc-200 bg-zinc-50 text-left text-xs uppercase tracking-wide text-zinc-500">
        <th class="px-4 py-2.5 font-medium">Key</th>
        <th class="px-4 py-2.5 font-medium">Class</th>
        <th class="px-4 py-2.5 font-medium">Stalled for</th>
        <th class="px-4 py-2.5 font-medium">Last step</th>
        <th class="px-4 py-2.5 font-medium">Last error</th>
        <th class="px-4 py-2.5 text-right font-medium">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-zinc-100">
      <% @rows.each do |r| %>
        <tr class="cursor-pointer hover:bg-zinc-50" data-href="<%= workflow_path(r.workflow) %>">
          <td class="px-4 py-2.5"><%= link_to r.workflow.key, workflow_path(r.workflow), class: "font-mono hover:underline" %></td>
          <td class="px-4 py-2.5 font-mono text-xs text-zinc-600"><%= r.workflow.job_class %></td>
          <td class="px-4 py-2.5 text-zinc-600"><%= cf_ago(r.stalled_since) %></td>
          <td class="px-4 py-2.5 font-mono text-xs text-zinc-600">
            <% if r.last_step %><span class="text-zinc-400"><%= cf_kind_label(r.last_step.kind) %></span> <%= r.last_step.name %><% else %>—<% end %>
          </td>
          <td class="px-4 py-2.5 text-xs">
            <% if r.last_error %>
              <span class="font-mono text-rose-600"><%= r.last_error.error_class %></span>
              <div class="truncate text-zinc-500"><%= truncate(r.last_error.error_message, length: 60) %></div>
            <% else %>
              <span class="text-zinc-400">—</span>
            <% end %>
          </td>
          <td class="px-4 py-2.5 text-right whitespace-nowrap">
            <%= button_to "Retry", retry_workflow_path(r.workflow), method: :post, class: "cf-btn" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @rows.none? %>
    <p class="px-4 py-12 text-center text-sm text-zinc-500">No stalled workflows. 🎉</p>
  <% end %>
</div>

<% if @capped %>
  <p class="mt-3 text-xs text-zinc-400">Showing the <%= @cap %> oldest stalled workflows. Use “Retry all” to clear the backlog.</p>
<% end %>
